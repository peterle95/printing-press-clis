{
  "manifest_version": "0.3",
  "name": "youtube-pp-mcp",
  "display_name": "Youtube Data",
  "version": "4.6.1",
  "description": "Youtube Data API surface as MCP tools.",
  "author": {
    "name": "CLI Printing Press"
  },
  "license": "Apache-2.0",
  "server": {
    "type": "binary",
    "entry_point": "bin/youtube-pp-mcp",
    "mcp_config": {
      "command": "${__dirname}/bin/youtube-pp-mcp",
      "args": [],
      "env": {
        "YOUTUBE_DATA_OAUTH2C": "${user_config.youtube_data_oauth2c}"
      }
    }
  },
  "user_config": {
    "youtube_data_oauth2c": {
      "type": "string",
      "title": "YOUTUBE_DATA_OAUTH2C",
      "description": "Sets YOUTUBE_DATA_OAUTH2C for the Youtube Data MCP server.",
      "sensitive": true,
      "required": true
    }
  },
  "compatibility": {
    "claude_desktop": ">=1.0.0",
    "platforms": [
      "darwin",
      "linux",
      "win32"
    ]
  }
}
